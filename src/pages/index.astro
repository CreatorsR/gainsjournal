---
import '../styles/tokens.css';
import { GUMLET_VIDEO_ID, VIDEO_AUTOPLAY, SHOW_DAY_BREAKDOWN } from '../config';

const videoSrc = `https://play.gumlet.io/embed/${GUMLET_VIDEO_ID}?background=false&autoplay=${VIDEO_AUTOPLAY}&loop=true&disable_player_controls=false`;

const days = [
  { label: 'DAY 1', title: 'Clarity', body: 'Lock in the one goal that actually matters. Drop the rest.' },
  { label: 'DAY 2', title: 'Rewire', body: 'A guided meditation that installs the goal where habits live.' },
  { label: 'DAY 3', title: 'Momentum', body: 'Turn ten quiet minutes into a system you run every day.' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>GainsJournal — Free 3-Day Goals & Meditation Challenge</title>
    <meta
      name="description"
      content="3 days. 10 minutes a day. The free Goals & Meditation Challenge rewires how you set goals — and how you hit them."
    />
    <link rel="canonical" href="https://gainsjournal.com/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Your goals aren't stuck. Your mind is." />
    <meta
      property="og:description"
      content="The free 3-Day Goals & Meditation Challenge. 10 minutes a day. Day 1 lands in your inbox immediately."
    />
    <meta property="og:url" content="https://gainsjournal.com/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    {import.meta.env.PROD && <script defer src="/_vercel/insights/script.js"></script>}
  </head>

  <body>
    <!-- Header: brand identity only, nothing competes with the CTA -->
    <header class="site-header">
      <a href="https://gainsjournal.com" class="wordmark">
        <span class="wm-gains">GAINS</span>
        <span class="wm-journal">JOURNAL</span>
        <span class="wm-tld">.COM</span>
      </a>
    </header>

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="hero-inner">
          <span class="chip anim-chip">
            <span class="chip-text">FREE 3-DAY CHALLENGE</span>
          </span>
          <h1>
            <span class="reveal-line"><span class="reveal-text">Your goals aren't stuck.</span></span>
            <span class="reveal-line"><span class="reveal-text accent reveal-delay">Your mind is.</span></span>
          </h1>
          <p class="hero-sub anim-late">
            3 days. 10 minutes a day. The Goals &amp; Meditation Challenge rewires how you set goals
            — and how you hit them.
          </p>
          <a href="#signup" class="btn anim-later" data-track="cta_click">Take the Challenge</a>
          <span class="reassure anim-later">Free · Starts the moment you sign up</span>
        </div>
      </section>

      <!-- Video -->
      <section class="video">
        <div class="video-frame">
          <iframe
            loading="lazy"
            title="Gumlet video player"
            src={videoSrc}
            referrerpolicy="origin"
            allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture; fullscreen; clipboard-write;"
          ></iframe>
        </div>
        <p class="video-caption">
          Watch: why willpower keeps failing you <span class="gold">— 90 seconds</span>
        </p>
      </section>

      <!-- Three-day breakdown -->
      {
        SHOW_DAY_BREAKDOWN && (
          <section class="days" id="days">
            <div class="days-inner">
              <div class="days-line" aria-hidden="true" />
              <div class="days-grid">
                {days.map((d, i) => (
                  <div class="day" style={`--stagger: ${i * 0.12}s`}>
                    <span class="day-label">{d.label}</span>
                    <h3>{d.title}</h3>
                    <p>{d.body}</p>
                  </div>
                ))}
              </div>
            </div>
          </section>
        )
      }

      <!-- Signup -->
      <section id="signup" class="signup">
        <h2>Three days from now, <span class="accent">you'll know.</span></h2>
        <p class="signup-sub">
          Join the free 3-Day Goals &amp; Meditation Challenge. Day 1 lands in your inbox
          immediately.
        </p>
        <form id="optin-form" novalidate>
          <input
            type="email"
            name="email"
            required
            placeholder="Your best email"
            aria-label="Email address"
            autocomplete="email"
          />
          <button type="submit">Start Day 1</button>
        </form>
        <p id="optin-success" class="success" hidden>
          You're in. Check your inbox — Day 1 is on its way.
        </p>
        <p id="optin-error" class="error" hidden>That email doesn't look right — try again.</p>
        <span class="fine-print">Free. No spam. Unsubscribe any time.</span>
      </section>
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <nav>
        <a href="https://gainsjournal.com/blog/10x-keto-secrets-secret-1/">Keto Hacking Secrets</a>
        <a href="https://gainsjournal.com/blog/attainment/">Goal Hacking</a>
        <a href="https://gainsjournal.com/blog/">The Journal</a>
      </nav>
      <span class="copyright">© 2026 GainsJournal.com</span>
    </footer>

    <!-- Sticky mobile CTA: appears after 50% scroll, hides at signup, dismissible -->
    <div id="sticky-cta" class="sticky-cta" role="complementary" aria-label="Challenge signup shortcut">
      <a href="#signup" class="btn sticky-btn" data-track="sticky_cta_click">Start Day 1 — Free</a>
      <button id="sticky-dismiss" class="sticky-dismiss" aria-label="Dismiss">&times;</button>
    </div>

    <script>
      // --- Analytics: named events pushed to dataLayer (GTM/GA-ready) ---
      const track = (event: string, data: Record<string, unknown> = {}) => {
        (window as any).dataLayer = (window as any).dataLayer || [];
        (window as any).dataLayer.push({ event, ...data });
        console.debug('[event]', event, data);
      };

      document.querySelectorAll<HTMLElement>('[data-track]').forEach((el) =>
        el.addEventListener('click', () => track(el.dataset.track!))
      );

      // --- Signup form (placeholder ESP wiring) ---
      const form = document.getElementById('optin-form') as HTMLFormElement | null;
      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const emailInput = form.elements.namedItem('email') as HTMLInputElement;
        const btn = form.querySelector('button')!;
        const success = document.getElementById('optin-success')!;
        const error = document.getElementById('optin-error')!;

        error.hidden = true;
        if (!emailInput.checkValidity() || !emailInput.value.includes('.')) {
          error.hidden = false;
          emailInput.focus();
          return;
        }

        btn.disabled = true;
        btn.textContent = 'Sending…';

        // TODO(ESP): replace this block with a POST to the real email service
        // (Flodesk/Kit/etc.), keep track('optin_submitted') on success and add
        // an error path that re-enables the button.
        await new Promise((r) => setTimeout(r, 500));
        console.info('[optin placeholder] captured email:', emailInput.value);

        track('optin_submitted');
        success.hidden = false;
        btn.textContent = "You're in";
        emailInput.disabled = true;
        document.getElementById('sticky-cta')?.remove();
      });

      // --- Day section: gold line draw + cell reveal on first view ---
      const daysSection = document.getElementById('days');
      if (daysSection && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const en of entries) {
              if (en.isIntersecting) {
                daysSection.classList.add('in-view');
                io.disconnect();
              }
            }
          },
          { threshold: 0.35 }
        );
        io.observe(daysSection);
      } else {
        daysSection?.classList.add('in-view');
      }

      // --- Sticky mobile CTA ---
      const sticky = document.getElementById('sticky-cta');
      const signupSection = document.getElementById('signup');
      let dismissed = false;
      let signupVisible = false;

      const updateSticky = () => {
        if (!sticky || dismissed) return;
        const doc = document.documentElement;
        const pct = window.scrollY / Math.max(1, doc.scrollHeight - window.innerHeight);
        sticky.classList.toggle('show', pct >= 0.5 && !signupVisible);
      };

      window.addEventListener('scroll', updateSticky, { passive: true });

      if (signupSection && 'IntersectionObserver' in window) {
        new IntersectionObserver(
          (entries) => {
            signupVisible = entries[0].isIntersecting;
            updateSticky();
          },
          { threshold: 0.1 }
        ).observe(signupSection);
      }

      document.getElementById('sticky-dismiss')?.addEventListener('click', () => {
        dismissed = true;
        sticky?.classList.remove('show');
      });
    </script>

    <style>
      /* ============ Base ============ */
      * {
        box-sizing: border-box;
      }
      html {
        background: var(--color-bg);
      }
      body {
        margin: 0;
        min-height: 100vh;
        background: var(--color-bg);
        color: var(--color-ink);
        font-family: var(--font-body);
        -webkit-font-smoothing: antialiased;
      }
      main {
        display: block;
      }
      .accent {
        color: var(--color-accent);
      }
      .gold {
        color: var(--color-gold);
      }
      :focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: 3px;
      }
      @media (prefers-reduced-motion: no-preference) {
        html {
          scroll-behavior: smooth;
        }
      }

      /* ============ Header ============ */
      .site-header {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 26px 24px 22px;
        border-bottom: 1px solid var(--border-faint);
      }
      .wordmark {
        text-decoration: none;
        display: flex;
        align-items: baseline;
        gap: 8px;
      }
      .wm-gains {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 20px;
        letter-spacing: 0.22em;
        color: var(--color-ink);
      }
      .wm-journal {
        font-family: var(--font-display);
        font-weight: 500;
        font-size: 20px;
        letter-spacing: 0.34em;
        color: var(--color-accent);
      }
      .wm-tld {
        font-size: 10px;
        letter-spacing: 0.18em;
        color: var(--ink-45);
      }

      /* ============ Hero ============ */
      .hero {
        position: relative;
        overflow: hidden;
      }
      .hero::before {
        content: '';
        position: absolute;
        inset: -30% -40%;
        background: radial-gradient(ellipse at 50% 35%, rgba(229, 25, 95, 0.09), transparent 58%);
        pointer-events: none;
      }
      .hero-inner {
        position: relative;
        max-width: 880px;
        margin: 0 auto;
        padding: 88px 24px 56px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 28px;
      }
      .chip {
        display: inline-block;
        background: var(--color-accent);
        color: #fff;
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 13px;
        letter-spacing: 0.24em;
        padding: 7px 18px;
        transform: skewX(var(--skew));
      }
      .chip-text {
        display: inline-block;
        transform: skewX(calc(-1 * var(--skew)));
      }
      h1 {
        margin: 0;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: clamp(44px, 7.5vw, 84px);
        line-height: 1.04;
        text-transform: uppercase;
        letter-spacing: 0.01em;
        text-wrap: balance;
      }
      .reveal-line {
        display: block;
        overflow: hidden;
      }
      .reveal-text {
        display: block;
      }
      .hero-sub {
        margin: 0;
        max-width: 520px;
        font-size: 19px;
        line-height: 1.55;
        color: var(--ink-72);
        text-wrap: pretty;
      }
      .btn {
        display: inline-block;
        background: var(--color-accent);
        color: #fff;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 17px;
        letter-spacing: 0.14em;
        padding: 16px 40px;
        text-transform: uppercase;
        transition: background 0.15s ease;
      }
      .btn:hover {
        background: var(--color-accent-hover);
      }
      .reassure {
        font-size: 12px;
        letter-spacing: 0.12em;
        color: var(--ink-40);
        text-transform: uppercase;
      }

      /* ============ Video ============ */
      .video {
        max-width: 880px;
        margin: 0 auto;
        padding: 0 24px 96px;
      }
      .video-frame {
        position: relative;
        aspect-ratio: 16 / 9;
        background: #000;
        border: 1px solid rgba(244, 242, 238, 0.1);
        box-shadow:
          0 30px 80px rgba(229, 25, 95, 0.12),
          0 20px 60px rgba(0, 0, 0, 0.6);
      }
      .video-frame iframe {
        border: none;
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        width: 100%;
      }
      .video-caption {
        margin: 18px 0 0;
        text-align: center;
        font-size: 13px;
        letter-spacing: 0.16em;
        color: var(--ink-40);
        text-transform: uppercase;
      }

      /* ============ Days ============ */
      .days {
        border-top: 1px solid var(--border-faint);
        border-bottom: 1px solid var(--border-faint);
        background: var(--color-band);
      }
      .days-inner {
        max-width: 1000px;
        margin: 0 auto;
        padding: 72px 24px;
      }
      .days-line {
        height: 2px;
        background: var(--color-gold);
        margin-bottom: 48px;
        transform-origin: left center;
      }
      .days-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 48px;
      }
      .day {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .day-label {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 15px;
        letter-spacing: 0.2em;
        color: var(--color-gold);
      }
      .day h3 {
        margin: 0;
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 26px;
        text-transform: uppercase;
        color: var(--color-ink);
      }
      .day p {
        margin: 0;
        font-size: 15px;
        line-height: 1.6;
        color: var(--ink-65);
      }

      /* ============ Signup ============ */
      .signup {
        max-width: 680px;
        margin: 0 auto;
        padding: 104px 24px 120px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
      }
      h2 {
        margin: 0;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: clamp(32px, 5vw, 52px);
        line-height: 1.1;
        text-transform: uppercase;
        text-wrap: balance;
      }
      .signup-sub {
        margin: 0;
        font-size: 17px;
        line-height: 1.55;
        color: var(--ink-68);
        max-width: 440px;
      }
      #optin-form {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
        width: 100%;
        max-width: 480px;
      }
      #optin-form input {
        flex: 1 1 240px;
        min-width: 0;
        background: var(--color-input);
        border: 1px solid var(--border-input);
        color: var(--color-ink);
        font-size: 16px;
        padding: 15px 18px;
        outline: none;
        font-family: var(--font-body);
      }
      #optin-form input:focus {
        border-color: var(--color-accent);
      }
      #optin-form button {
        flex: 0 0 auto;
        font-size: 15px;
        padding: 15px 30px;
        background: var(--color-accent);
        color: #fff;
        border: none;
        cursor: pointer;
        font-family: var(--font-display);
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        transition: background 0.15s ease;
      }
      #optin-form button:hover:not(:disabled) {
        background: var(--color-accent-hover);
      }
      #optin-form button:disabled {
        cursor: default;
        opacity: 0.85;
      }
      .success {
        margin: 0;
        color: var(--color-gold);
        font-size: 15px;
      }
      .error {
        margin: 0;
        color: var(--color-accent-hover);
        font-size: 14px;
      }
      .fine-print {
        font-size: 12px;
        letter-spacing: 0.1em;
        color: var(--ink-38);
      }

      /* ============ Footer ============ */
      .site-footer {
        border-top: 1px solid var(--border-faint);
        padding: 36px 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 14px;
      }
      .site-footer nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 28px;
      }
      .site-footer nav a {
        color: var(--ink-55);
        text-decoration: none;
        font-size: 12px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        transition: color 0.15s ease;
      }
      .site-footer nav a:hover {
        color: var(--color-ink);
      }
      .copyright {
        font-size: 12px;
        color: var(--ink-35);
      }

      /* ============ Sticky mobile CTA ============ */
      .sticky-cta {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 50;
        display: none;
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        background: rgba(11, 11, 13, 0.92);
        backdrop-filter: blur(8px);
        border-top: 1px solid var(--border-faint);
        transform: translateY(110%);
        transition: transform 0.3s ease;
      }
      .sticky-cta.show {
        transform: translateY(0);
      }
      .sticky-btn {
        flex: 1;
        text-align: center;
        font-size: 15px;
        padding: 13px 16px;
      }
      .sticky-dismiss {
        flex: 0 0 auto;
        background: none;
        border: none;
        color: var(--ink-55);
        font-size: 24px;
        line-height: 1;
        padding: 8px 10px;
        cursor: pointer;
      }
      @media (max-width: 767px) {
        .sticky-cta {
          display: flex;
        }
      }

      /* ============ Motion (opt-in only) ============ */
      @media (prefers-reduced-motion: no-preference) {
        /* Hero headline: lines rise in with a stagger, then the page is still */
        .reveal-text {
          transform: translateY(110%);
          animation: gj-rise 0.55s cubic-bezier(0.2, 0.7, 0.2, 1) 0.1s forwards;
        }
        .reveal-delay {
          animation-delay: 0.22s;
        }
        .anim-chip,
        .anim-late,
        .anim-later {
          opacity: 0;
          animation: gj-fade-up 0.5s ease forwards;
        }
        .anim-chip {
          animation-delay: 0s;
        }
        .anim-late {
          animation-delay: 0.4s;
        }
        .anim-later {
          animation-delay: 0.52s;
        }

        /* Hero glow: very slow drift */
        .hero::before {
          animation: gj-glow 14s ease-in-out infinite alternate;
        }

        /* Day band: gold line draws, cells rise, on first view */
        .days-line {
          transform: scaleX(0);
          transition: transform 0.8s cubic-bezier(0.2, 0.7, 0.2, 1);
        }
        .days.in-view .days-line {
          transform: scaleX(1);
        }
        .day {
          opacity: 0;
          transform: translateY(14px);
          transition:
            opacity 0.5s ease var(--stagger, 0s),
            transform 0.5s ease var(--stagger, 0s);
        }
        .days.in-view .day {
          opacity: 1;
          transform: none;
        }

        /* Success message pulse */
        .success {
          animation: gj-pulse 2s ease-in-out infinite;
        }
      }

      @keyframes gj-rise {
        to {
          transform: translateY(0);
        }
      }
      @keyframes gj-fade-up {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }
      @keyframes gj-glow {
        from {
          transform: translate(-3%, 0) scale(1);
          opacity: 0.8;
        }
        to {
          transform: translate(3%, 2%) scale(1.08);
          opacity: 1;
        }
      }
      @keyframes gj-pulse {
        0%,
        100% {
          opacity: 0.55;
        }
        50% {
          opacity: 1;
        }
      }
    </style>
  </body>
</html>
